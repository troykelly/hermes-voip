# Example environment for hermes-voip — PLACEHOLDER VALUES ONLY.
# Copy to `.env` (gitignored) and fill with the real values from 1Password.
# The repo is PUBLIC: never commit real host/extension/password values here.

# SIP-over-TLS / WebRTC voice gateway (any RFC-compliant gateway; values are fake examples).
HERMES_SIP_SERVER_HOST=pbx.example.test
HERMES_SIP_WEB_UI=https://pbx.example.test/
HERMES_SIP_EXTENSION=1000
HERMES_SIP_USERNAME=1000
HERMES_SIP_PASSWORD=change-me

# Conversational media (optional; every key has a safe default — see docs/adr/0006..0010).
# Opening line the agent speaks the instant an inbound call is answered. Speaking on
# answer makes the plugin send RTP first, so the caller hears it immediately and a
# gateway behind NAT can latch onto our source (symmetric RTP). Unset uses a friendly
# default; set it to empty to disable the greeting entirely.
# HERMES_VOIP_GREETING=Hello, you're through to the Hermes voice assistant. How can I help?

# Symmetric-RTP (comedia) latching for NAT traversal. When true (the default) the
# media engine sends our RTP to the peer's REAL source (the source of the first valid
# inbound RTP packet) instead of the SDP c=/m= address, so two-way audio works when
# either side is behind NAT. Set false to always honour the SDP address (for gateways
# that route RTP strictly by the negotiated address).
# HERMES_VOIP_RTP_SYMMETRIC=true

# Outbound call-on-connect (ADR-0019 Phase 1): when set, the adapter places one
# outbound call to the named extension immediately after the first successful
# registration. Useful for AFK test calls or scheduled outbound sessions.
# The flag fires exactly once per adapter instance (reconnects do not re-fire it).
# Set to the target SIP extension (numeric string) or leave unset to disable.
# HERMES_VOIP_CALL_ON_CONNECT=1001
