# Example environment for hermes-voip — PLACEHOLDER VALUES ONLY.
# Copy to `.env` (gitignored) and fill with the real values from 1Password.
# The repo is PUBLIC: never commit real host/extension/password values here.

# SIP-over-TLS voice gateway (any RFC-compliant gateway; values are fake examples).
# These are the keys the plugin reads (src/hermes_voip/config.py): HOST is the SIP
# registrar FQDN; PORT defaults to 5061; TRANSPORT defaults to tls (wss is roadmap).
HERMES_SIP_HOST=pbx.example.test
# HERMES_SIP_PORT=5061
# HERMES_SIP_TRANSPORT=tls
HERMES_SIP_EXTENSION=1000
HERMES_SIP_USERNAME=1000
HERMES_SIP_PASSWORD=change-me

# Conversational media providers (optional). The defaults select the fully-offline
# self-host path (no cloud, no API key) — but that path needs the local model dirs
# below set (TTS_MODEL + STT_MODEL_DIR + INJECTION_GUARD_MODEL_DIR) or provider build
# fails fast. TTS: HERMES_VOIP_TTS_PROVIDER=sherpa-kokoro (default, local) | elevenlabs
# (cloud, needs ELEVENLABS_API_KEY). STT: HERMES_VOIP_STT_PROVIDER=sherpa-onnx
# (default, local) | deepgram (cloud, needs DEEPGRAM_API_KEY). See README + ADR-0006/0007/0009.
# HERMES_VOIP_TTS_PROVIDER=sherpa-kokoro
# HERMES_VOIP_TTS_VOICE=
# HERMES_VOIP_TTS_MODEL=/path/to/kokoro-model-dir
# HERMES_VOIP_STT_PROVIDER=sherpa-onnx
# HERMES_VOIP_STT_MODEL_DIR=/path/to/stt-model-dir
# HERMES_VOIP_INJECTION_GUARD_MODEL_DIR=/path/to/guard-model-dir
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=

# Greeting + NAT (optional; every key has a safe default — see docs/adr/0002,0005).
# Opening line the agent speaks the instant an inbound call is answered. Speaking on
# answer makes the plugin send RTP first, so the caller hears it immediately and a
# gateway behind NAT can latch onto our source (symmetric RTP). Unset uses a friendly
# default; set it to empty to disable the greeting entirely.
# HERMES_VOIP_GREETING=Hello, you're through to the Hermes voice assistant. How can I help?

# Symmetric-RTP (comedia) latching for NAT traversal. When true (the default) the
# media engine sends our RTP to the peer's REAL source (the source of the first valid
# inbound RTP packet) instead of the SDP c=/m= address, so two-way audio works when
# either side is behind NAT. Set false to always honour the SDP address (for gateways
# that route RTP strictly by the negotiated address).
# HERMES_VOIP_RTP_SYMMETRIC=true

# Outbound call-on-connect (ADR-0019 Phase 1): when set, the adapter places one
# outbound call to the named extension immediately after the first successful
# registration. Useful for AFK test calls or scheduled outbound sessions.
# The flag fires exactly once per adapter instance (reconnects do not re-fire it).
# Set to the target SIP extension (numeric string) or leave unset to disable.
# HERMES_VOIP_CALL_ON_CONNECT=1001

# ---------------------------------------------------------------------------
# Caller groups (ADR-0021) — N named trust tiers per caller.
# See docs/runbooks/0003-voip-caller-modes.md for the full runbook.
#
# SECURITY MODEL: the remote party on ANY call is UNTRUSTED unless allow-listed
# — including the callee on an OUTBOUND call. Caller-ID is FORGEABLE and is NOT
# an authentication boundary. Caller group is a CEILING, never a bypass:
# - privilege_level=0 (receptionist): SAFE-only tools — no hold/transfer.
# - privilege_level=2 (trusted): +ELEVATED tools (hold/resume), no transfer.
# - privilege_level=3 (operator/assistant): +IRREVERSIBLE (transfer), still
#   requires ADR-0010 DTMF confirmation + non-degraded session.
# An unmatched caller is the default group (receptionist, privilege_level=0).
#
# PII: phone numbers are PII and must NEVER be committed. The lists live in
# gitignored JSON files; ONLY file PATHS go in env — inline number lists are
# rejected (they would leak into shell history / printenv).
#
# OPTION A — new N-group config file (ADR-0021):
# HERMES_VOIP_CALLER_GROUPS_FILE=/run/secrets/.hermes-caller-groups.json
# Format: see docs/runbooks/0003-voip-caller-modes.md for the JSON schema.
#
# OPTION B — legacy 3-file scheme (ADR-0020; backward compat):
# List-file format: { "patterns": ["+15555550100", "1000", "+15550*"] }
#   - exact value OR "*"-suffixed literal prefix; an unset var => empty list.
# HERMES_VOIP_CALLER_ALLOW_FILE=/run/secrets/.caller-allow.json
# HERMES_VOIP_CALLER_DENY_FILE=/run/secrets/.caller-deny.json
# HERMES_VOIP_CALLER_GREY_FILE=/run/secrets/.caller-grey.json
#   - Default for an UNMATCHED caller: only "grey" (the safe receptionist) is
#     valid. "allow" is REFUSED at startup (ConfigError) — it would grant operator
#     privilege to every unknown, forgeable caller. Operator privilege needs an
#     explicit allow-list match, never the default.
# HERMES_VOIP_CALLER_DEFAULT_MODE=grey
# HERMES_VOIP_CALLER_NORMALIZATION=e164
#
# Hermes pairing flow (GATEWAY_ALLOW_ALL_USERS): when running behind a Hermes
# gateway that uses its own user-pairing flow, callers are matched BEFORE caller
# groups run and the pairing flow can pre-empt the group classification. Set
# GATEWAY_ALLOW_ALL_USERS=true to disable the Hermes pairing gate so caller
# groups are the sole admission control (the correct production setting when
# using caller groups as the authentication surface).
# GATEWAY_ALLOW_ALL_USERS=true
