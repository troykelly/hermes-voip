# Example environment for hermes-voip — PLACEHOLDER VALUES ONLY.
# Copy to `.env` (gitignored) and fill with the real values from 1Password.
# The repo is PUBLIC: never commit real host/extension/password values here.

# SIP voice gateway (any RFC-compliant gateway; values are fake examples).
# These are the keys the plugin reads (src/hermes_voip/config.py): HOST is the SIP
# registrar FQDN; PORT defaults to 5061 (tls) / 443 (wss); TRANSPORT defaults to tls.
# Provisioning aliases: HERMES_SIP_SERVER_HOST is accepted as a fallback for
# HERMES_SIP_HOST, and HERMES_SIP_TLS_PORT as a fallback for HERMES_SIP_PORT (the
# names the 1Password provisioner emits). The canonical HERMES_SIP_HOST / _PORT win
# when both are set; either name loads the value (runbook 0001).
HERMES_SIP_HOST=pbx.example.test
# HERMES_SIP_PORT=5061
# HERMES_SIP_TRANSPORT=tls
HERMES_SIP_EXTENSION=1000
HERMES_SIP_USERNAME=1000
HERMES_SIP_PASSWORD=change-me

# SIP-over-Secure-WebSocket (WebRTC signalling, RFC 7118 / ADR-0038). Set
# HERMES_SIP_TRANSPORT=wss to register + receive calls over wss://HOST:PORT/PATH
# (subprotocol sip); a SAVPF/DTLS/ICE INVITE then flows through the WebRTC media
# path (ADR-0032). The WSS endpoint is commonly a DIFFERENT port + a DIFFERENT
# digest password than the SIP-TLS edge:
#   HERMES_SIP_PORT          — the WSS port (e.g. the gateway's WebRTC port).
#   HERMES_SIP_WS_PATH       — the WebSocket upgrade path (default /ws).
#   HERMES_SIP_WS_PASSWORD   — the SEPARATE WSS digest password; UNSET => fall back
#                              to HERMES_SIP_PASSWORD. A SECRET — gitignored .env /
#                              1Password only, never a tracked file.
# Live WSS validation needs the operator's real WSS port + HERMES_SIP_WS_PASSWORD.
# HERMES_SIP_TRANSPORT=wss
# HERMES_SIP_PORT=8090
# HERMES_SIP_WS_PATH=/ws
# HERMES_SIP_WS_PASSWORD=change-me

# Conversational media providers (optional). The defaults select the fully-offline
# self-host path (no cloud, no API key) — but that path needs the local model dirs
# below set (TTS_MODEL + STT_MODEL_DIR + INJECTION_GUARD_MODEL_DIR + VAD_MODEL_DIR) or
# provider/VAD build fails fast. TTS: HERMES_VOIP_TTS_PROVIDER=sherpa-kokoro (default,
# local) | elevenlabs (cloud, needs ELEVENLABS_API_KEY). STT: HERMES_VOIP_STT_PROVIDER=
# sherpa-onnx (default, local) | deepgram (cloud, needs DEEPGRAM_API_KEY). The other TTS
# tokens (piper/kittentts/kyutai/cartesia/aura2) are RESERVED in config but not yet wired —
# selecting one fails fast at provider build. See README + ADR-0006/0007/0009.
# HERMES_VOIP_TTS_PROVIDER=sherpa-kokoro
# HERMES_VOIP_TTS_VOICE=
# HERMES_VOIP_TTS_MODEL=/path/to/kokoro-model-dir
# HERMES_VOIP_STT_PROVIDER=sherpa-onnx
# HERMES_VOIP_STT_MODEL_DIR=/path/to/stt-model-dir
# HERMES_VOIP_INJECTION_GUARD_MODEL_DIR=/path/to/guard-model-dir
# Silero VAD model dir (ml extra): the directory holding silero_vad.onnx, used to
# endpoint every inbound call. Required for the self-host path (the model is never
# downloaded here); a missing file raises a clear FileNotFoundError at call setup.
# HERMES_VOIP_VAD_MODEL_DIR=/path/to/silero-vad-dir
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=
# HERMES_VOIP_CARTESIA_API_KEY=   # reserved (cartesia TTS not yet wired)

# Automatic TTS failover (ADR-0025): if the PRIMARY synthesiser raises mid-call (an
# HTTP error, a timeout, a dropped stream) the call falls back to a second synthesiser
# so the caller hears audio instead of silence. HERMES_VOIP_TTS_FALLBACK selects the
# fallback provider; UNSET defaults per primary — a CLOUD primary (elevenlabs) falls
# back to local sherpa-kokoro, a self-host primary defaults to none. `none` disables it.
# The fallback must be a known TTS provider that DIFFERS from the primary.
# HERMES_VOIP_TTS_FALLBACK=sherpa-kokoro
# A sherpa-kokoro fallback needs its OWN model dir: the shared HERMES_VOIP_TTS_MODEL is
# the ElevenLabs model id for a cloud primary, NOT a Kokoro path. Validated at startup
# (a model-backed fallback without this fails loud, never silently on first failure).
# HERMES_VOIP_TTS_FALLBACK_MODEL=/path/to/kokoro-model-dir

# ---------------------------------------------------------------------------
# ElevenLabs dynamic-voice tuning (only when HERMES_VOIP_TTS_PROVIDER=elevenlabs).
# Full guidance + the latency/expressiveness tradeoffs: docs/runbooks/0004-voip-tts-voice.md.
#
# The DEFAULT is already dynamic-but-stable (stability 0.35 < ElevenLabs' flat 0.5),
# so a bare ElevenLabs install is livelier than the API default with no tuning.
# Every knob below is OPTIONAL: unset => the dynamic default for that field. They
# let the operator A/B voice dynamism on live calls WITHOUT a code change.
#
# Model: for ElevenLabs, HERMES_VOIP_TTS_MODEL is the MODEL ID (not a path; the
# path meaning is only for the self-host sherpa-kokoro provider). Two first-class
# tiers (ADR-0027), both fine on the phone path (the Hermes LLM turn dominates):
#   eleven_flash_v2_5  — default; lowest first-audio (~310 ms measured); audio tags
#                        are STRIPPED (never spoken).
#   eleven_v3          — most expressive; ~454 ms first-audio (measured); the agent's
#                        audio tags ([breath]/[laughs]/[sighs]/[hesitates]/...) RENDER.
# On any non-v3 model (Flash/Turbo/Multilingual, and the sherpa-kokoro fallback) tags
# are stripped so a bracketed cue is never read aloud literally. Do NOT use
# eleven_v3_conversational (Agents-platform only; 401 with a standard TTS key).
# HERMES_VOIP_TTS_MODEL=eleven_flash_v2_5   # or eleven_v3 for expressive + audio tags
#
# voice_settings (floats 0.0-1.0). stability is the main dynamism dial: LOWER =
# broader emotional range; too low = inconsistent. style adds expression but costs
# stability + latency (keep 0.0 on telephony; try 0.10-0.15 only if needed).
# HERMES_VOIP_TTS_STABILITY=0.35
# HERMES_VOIP_TTS_STYLE=0.0
# HERMES_VOIP_TTS_SIMILARITY=0.75
# HERMES_VOIP_TTS_SPEAKER_BOOST=true
#
# optimize_streaming_latency (int 0-4): deprecated; UNSET by default. Flash +
# pcm_8000 already keep first-audio latency low. 1 = mild optimisation if ever
# needed; never 4 (it disables number/date normalisation — bad for a receptionist).
# HERMES_VOIP_TTS_STREAMING_LATENCY=1
#
# Starter voices (ElevenLabs PUBLIC premade voice_ids; swap by setting
# HERMES_VOIP_TTS_VOICE). These are a STARTING POINT from ElevenLabs' default
# library (available to standard accounts; availability can vary by plan). The
# plugin accepts ANY ElevenLabs voice_id — including your own custom/cloned voices.
# The settings above apply to whichever voice you pick. Each id was verified to
# synthesize (HTTP 200) on 2026-06-17; the TTS-scoped key cannot list voices and
# the ids are ElevenLabs' (may change), so confirm a swap by a live call.
# Fuller table: docs/runbooks/0004-voip-tts-voice.md.
#   SAz9YHcvj6GT2YYXdXww  River     gender-neutral, calm, US (good neutral default)
#   21m00Tcm4TlvDq8ikWAM  Rachel    female, calm narration, US (shipped baseline)
#   EXAVITQu4vr4xnSDxMaL  Sarah     female, soft, conversational, US
#   cgSgspJ2msm6clMCkdW9  Jessica   female, expressive/animated, US
#   FGY2WhTYpPnrIDTdsKH5  Laura     female, bright, upbeat, US
#   Xb7hH8MSUJpSbSDYk0k2  Alice     female, clear, British
#   TX3LPaxmHKxFdv7VOQHJ  Liam      male, younger, US
#   TxGEqnHWrfWFTfGW9XjX  Josh      male, younger, deep, US
#   pqHfZKP75CvOlQylNhV4  Bill      male, older, deep, trustworthy, US
#   nPczCjzI2devNBz1zQrb  Brian     male, deep, narration, US
#   JBFqnCBsd6RMkjVDRZzb  George    male, warm, British
#   onwK4e9ZLuTAKqWW03F9  Daniel    male, authoritative, British
#   IKne3meq5aSn9XLyUdCD  Charlie   male, casual, Australian
#   cjVigY5qzO86Huf0OWal  Eric      male, friendly, US
# HERMES_VOIP_TTS_VOICE=21m00Tcm4TlvDq8ikWAM

# Greeting + NAT (optional; every key has a safe default — see docs/adr/0002,0005).
# Opening line the agent speaks the instant an inbound call is answered. Speaking on
# answer makes the plugin send RTP first, so the caller hears it immediately and a
# gateway behind NAT can latch onto our source (symmetric RTP). Unset uses a friendly
# default; set it to empty to disable the greeting entirely.
# HERMES_VOIP_GREETING=Hello, you're through to the Hermes voice assistant. How can I help?

# Symmetric-RTP (comedia) latching for NAT traversal. When true (the default) the
# media engine sends our RTP to the peer's REAL source (the source of the first valid
# inbound RTP packet) instead of the SDP c=/m= address, so two-way audio works when
# either side is behind NAT. Set false to always honour the SDP address (for gateways
# that route RTP strictly by the negotiated address).
# HERMES_VOIP_RTP_SYMMETRIC=true

# Connection keepalive interval (seconds). Seconds between the RFC 5626 §5.4
# double-CRLF keepalive pings the transport sends to keep the gateway's NAT binding
# and flow alive (this is the connection ping, not the registration refresh — that is
# HERMES_SIP_EXPIRES). Float seconds; default 30.0; 0 or negative disables pings.
# HERMES_VOIP_KEEPALIVE_INTERVAL=30.0

# RTP-inactivity watchdog (ADR-0026). A silent media/network drop otherwise hangs the
# call forever; when no inbound RTP arrives within this window the call ends as a
# MEDIA_TIMEOUT (a failure end -> a /stop signal to the Hermes session). The deadline
# re-arms on every inbound datagram, so a live call is never false-killed. Integer
# seconds in [1, 300]; default 20. (0 is rejected — the safety watchdog is not
# operator-disablable.) See docs/runbooks/0005-voip-rtp-inactivity-timeout.md.
# HERMES_VOIP_RTP_TIMEOUT_SECS=20

# WebRTC media plane (ADR-0032). The plugin serves an inbound WebRTC peer (a peer
# offering UDP/TLS/RTP/SAVPF) with DTLS-SRTP keying, ICE connectivity, and Opus at
# 48 kHz — co-equal to SIP-over-TLS. NO new env is required for a LAN / direct-reach
# peer (host-only ICE works). The Opus codec needs the `webrtc` extra PLUS the system
# `libopus` shared library at runtime (apt: libopus0); without it a WebRTC/Opus call
# fails with a clear ImportError and SIP-over-TLS is unaffected.
#
# HERMES_VOIP_ICE_STUN_URLS — comma-separated stun: URLs for server-reflexive (srflx)
# ICE candidates, for a peer that cannot reach our host candidates directly (NAT).
# Empty (the default) = host-only ICE. SIP-over-WSS signalling is wired (set
# HERMES_SIP_TRANSPORT=wss above), and OUTBOUND WebRTC origination (WebRTC/Opus over
# WSS) ships too (ADR-0049).
# HERMES_VOIP_ICE_STUN_URLS=stun:stun.example.test:3478,stun:stun2.example.test:3478
#
# HERMES_VOIP_ICE_TURN_URLS / _TURN_USERNAME / _TURN_PASSWORD (ADR-0034) — a TURN relay
# for when neither host nor STUN-reflexive works (symmetric NAT). The plugin CONSUMES an
# operator-provided TURN server (turn:/turns: URL, RFC 7065); it does not run one. URLs
# set ⇒ username + password are REQUIRED (RFC 8656 §9.2) or the plugin refuses to start.
# The password is a secret — keep it here (gitignored) / in 1Password, never in a tracked
# file. Empty (the default) = no relay candidate.
# HERMES_VOIP_ICE_TURN_URLS=turn:turn.example.test:3478?transport=udp
# HERMES_VOIP_ICE_TURN_USERNAME=relay-user
# HERMES_VOIP_ICE_TURN_PASSWORD=change-me

# Echo-robust barge-in (ADR-0023). Some gateways reflect the agent's own TTS
# back on the inbound path (no echo cancellation); the VAD/ASR then transcribe
# it as the caller and a single onset interrupts the agent — a self-interruption
# loop. Mode `gated` (the default) requires a SUSTAINED voiced run while the
# agent's TTS is playing (and a short tail after) before a barge-in counts, so
# short echo blips never interrupt but a genuine sustained interruption still
# does. `full` is the legacy immediate barge-in (only for echo-cancelled
# gateways); `off` disables barge-in entirely.
# HERMES_VOIP_BARGE_IN_MODE=gated
# Minimum sustained voiced speech (ms) to barge in / deliver a turn while TTS plays.
# AEC-AWARE DEFAULT: 200 when the echo canceller is ON (the default — the echo is
# cancelled before the VAD, so a responsive 200 ms is safe), 600 when AEC is OFF
# (the echo-safety margin, above the longest observed gateway-echo burst). An
# explicit value here always wins over the AEC-aware default.
# HERMES_VOIP_BARGE_IN_MIN_SPEECH_MS=200
# How long after the agent's TTS ends the gate keeps requiring a sustained run
# (ms; echo lags the TTS via jitter/network). 0 disarms the instant TTS ends.
# HERMES_VOIP_BARGE_IN_TAIL_MS=250
# Clean-stop fade (ADR-0028): when a barge-in is authorised the engine flushes the
# agent's already-queued audio so it goes quiet within ~1 packet, applying a short
# linear fade-out over this many ms on the final frames so the cut is click-free.
# Default 30; 0 = instant hard cut.
# HERMES_VOIP_BARGE_IN_FADE_MS=30

# In-process acoustic echo cancellation (ADR-0033). ON by default. The gateway
# reflects the agent's own TTS back on the inbound leg; the canceller subtracts the
# KNOWN outbound TTS reference from each inbound frame (an NLMS adaptive filter,
# pure-stdlib — no extra dependency) BEFORE the VAD/ASR see it, so the reflected echo
# cannot false-trigger barge-in. That is what lets HERMES_VOIP_BARGE_IN_MIN_SPEECH_MS
# default to a responsive 200 ms instead of 600 ms. Setting it false reverts to the
# ADR-0023 sustained-gate-only behaviour (and the 600 ms default). The canceller adds
# no algorithmic delay (per-sample, buffer-free). See
# docs/runbooks/0012-voip-acoustic-echo-cancellation.md.
# HERMES_VOIP_AEC_ENABLED=true
# Adaptive-filter length in ms (spans the echo path's impulse response). Default 16
# (captures the dominant echo energy within the per-frame CPU budget; 32 is ~2x CPU).
# HERMES_VOIP_AEC_FILTER_MS=16
# A fixed reference delay (ms) skipped before the adaptive window, for a gateway with
# a large constant echo-return delay. Default 0 (the taps cover the delay directly).
# HERMES_VOIP_AEC_BULK_DELAY_MS=0
# NLMS step size in the OPEN interval (0, 2). Higher converges faster with a higher
# steady-state residual. Default 0.30.
# HERMES_VOIP_AEC_MU=0.30

# Conversation language (ADR-0054). Selects the built-in comfort-filler phrase set;
# English only for now. Validated against the known set (an unknown code fails at
# startup). Default "en".
# HERMES_VOIP_LANGUAGE=en

# Dead-air comfort filler (ADR-0030, extended ADR-0054). ON by default. On a slow turn
# there is a gap of pure silence between the caller finishing and the agent's first
# audio (LLM think time + TTS first-audio latency); on a phone call that reads as a
# dropped line. The call loop emits a short, natural human filler ("One moment please.")
# once the gap exceeds the delay, then RE-EMITS a fresh random phrase every repeat
# interval until the reply audio starts — so a long ~10 s wait is not mostly silence —
# cancelled the instant the reply or a barge-in arrives. The filler routes through the
# normal TTS path, so it is flushable (ADR-0028) and renders model-appropriately (a bare
# phrase reads naturally on any model; a v3 tag like "[hesitates]" renders on eleven_v3
# and is stripped elsewhere — ADR-0027). Set false for the pre-filler behaviour exactly.
# See docs/runbooks/0006-voip-comfort-filler.md.
# HERMES_VOIP_TTS_COMFORT_FILLER=false
# Dead-air threshold (ms) before the FIRST filler fires. Must be > 0. Default 900 — long
# enough that a brisk reply never triggers it, short enough that a slow turn does not
# leave the caller in silence.
# HERMES_VOIP_TTS_COMFORT_FILLER_DELAY_MS=900
# Periodic interval (ms) between subsequent fillers on a sustained gap. Must be > 0.
# Default 900 (same cadence as the delay).
# HERMES_VOIP_TTS_COMFORT_FILLER_REPEAT_MS=900
# The filler phrase set, `|`-separated; one is chosen at RANDOM per fill, never repeating
# the immediately-previous phrase. Trimmed; empty members dropped; blank/unset falls back
# to the selected language's built-in set. A varied set wears better than a few phrases.
# Keep each phrase short (~0.3-0.8 s spoken).
# HERMES_VOIP_TTS_COMFORT_FILLER_PHRASES=One moment please.|Bear with me.|Just a second.

# Outbound call-on-connect (ADR-0019 Phase 1): when set, the adapter places one
# outbound call to the named extension immediately after the first successful
# registration. Useful for AFK test calls or scheduled outbound sessions.
# The flag fires exactly once per adapter instance (reconnects do not re-fire it).
# Set to the target SIP extension (numeric string) or leave unset to disable.
# HERMES_VOIP_CALL_ON_CONNECT=1001

# Agent-triggered outbound calls (ADR-0029) — the `place_call(number, objective)`
# tool. The agent can place a call to accomplish a task; it runs as its own
# conversation that opens with the objective, and the outcome is reported back to the
# conversation that asked for it. See docs/runbooks/0007-voip-outbound-calling.md.
#
# HERMES_VOIP_OUTBOUND_ALLOW is the HARD GATE: a comma-separated allowlist of
# permitted dial targets (extensions and/or SIP URIs). EMPTY BY DEFAULT => the
# feature is INERT (no number may be dialled) until you opt numbers in. Matching is
# EXACT (a listed 1000 does not permit 10000). place_call is also IRREVERSIBLE and
# clamped to an operator (level-3), non-degraded session, so an untrusted inbound
# caller can never trigger it. NEVER put operator secrets in the objective — the
# person you call is untrusted. Dial targets are PII-class: gitignored .env only.
# HERMES_VOIP_OUTBOUND_ALLOW=1000,1001,sip:reception@pbx.example.test
#
# Where the outcome of a call NOT triggered by an agent turn (the CALL_ON_CONNECT /
# cron path, which has no originating session) is reported — a platform:chat_id
# target. Unset => such outcomes are logged only (voip has no home channel of its
# own). A call triggered by an agent always reports to its origin session.
# HERMES_VOIP_OUTBOUND_RESULT_CHANNEL=telegram:123456789

# ---------------------------------------------------------------------------
# Caller groups (ADR-0021) — N named trust tiers per caller.
# See docs/runbooks/0010-voip-caller-modes.md for the full runbook.
#
# SECURITY MODEL: the remote party on ANY call is UNTRUSTED unless allow-listed
# — including the callee on an OUTBOUND call. Caller-ID is FORGEABLE and is NOT
# an authentication boundary. Caller group is a CEILING, never a bypass:
# - privilege_level=0 (receptionist): SAFE-only tools — no hold/transfer.
# - privilege_level=2 (trusted): +ELEVATED tools (hold/resume), no transfer.
# - privilege_level=3 (operator/assistant): +IRREVERSIBLE (transfer), still
#   requires ADR-0010 DTMF confirmation + non-degraded session.
# An unmatched caller is the default group (receptionist, privilege_level=0).
#
# PII: phone numbers are PII and must NEVER be committed. The lists live in
# gitignored JSON files; ONLY file PATHS go in env — inline number lists are
# rejected (they would leak into shell history / printenv).
#
# OPTION A — new N-group config file (ADR-0021):
# HERMES_VOIP_CALLER_GROUPS_FILE=/run/secrets/.hermes-caller-groups.json
# Format: see docs/runbooks/0010-voip-caller-modes.md for the JSON schema.
#
# OPTION B — legacy 3-file scheme (ADR-0020; backward compat):
# List-file format: { "patterns": ["+15555550100", "1000", "+15550*"] }
#   - exact value OR "*"-suffixed literal prefix; an unset var => empty list.
# HERMES_VOIP_CALLER_ALLOW_FILE=/run/secrets/.caller-allow.json
# HERMES_VOIP_CALLER_DENY_FILE=/run/secrets/.caller-deny.json
# HERMES_VOIP_CALLER_GREY_FILE=/run/secrets/.caller-grey.json
#   - Default for an UNMATCHED caller: only "grey" (the safe receptionist) is
#     valid. "allow" is REFUSED at startup (ConfigError) — it would grant operator
#     privilege to every unknown, forgeable caller. Operator privilege needs an
#     explicit allow-list match, never the default.
# HERMES_VOIP_CALLER_DEFAULT_MODE=grey
# HERMES_VOIP_CALLER_NORMALIZATION=e164
#
# Hermes pairing flow (GATEWAY_ALLOW_ALL_USERS): when running behind a Hermes
# gateway that uses its own user-pairing flow, callers are matched BEFORE caller
# groups run and the pairing flow can pre-empt the group classification. Set
# GATEWAY_ALLOW_ALL_USERS=true to disable the Hermes pairing gate so caller
# groups are the sole admission control (the correct production setting when
# using caller groups as the authentication surface).
# GATEWAY_ALLOW_ALL_USERS=true

# ---------------------------------------------------------------------------
# Intercom entry actuation (ADR-0031) — the `open_entry` tool / intercom caller mode.
# See docs/runbooks/0008-voip-intercom-and-dtmf.md for the full runbook + JSON example.
#
# The intercom caller mode answers a door/gate intercom, screens the visitor, and
# (for a legitimate expected visitor) OPENS the entry. Wire it as a CALLER GROUP
# (above) at privilege_level=2 with an `allowed_tools` SUB-CEILING scoped to ONLY
# the entry action, e.g. in the N-group JSON:
#   { "name": "intercom", "privilege_level": 2, "persona": "intercom",
#     "allowed_tools": ["open_entry"] }
# and put the door-phone's caller-ID (a digit-bearing pattern) on its list. Because
# of the sub-ceiling, even a SPOOFED caller-ID landing in this group can reach ONLY
# open_entry — never operator tools or secrets.
#
# HERMES_VOIP_INTERCOM_OPEN_MODE selects HOW open_entry actuates. DEFAULT = disabled
# => open_entry RAISES a clear error (a door is never opened, and never silently
# fails to open). Two paths (operator: "build both"):
#
#   dtmf  — send a DTMF open code on the LIVE call (the door phone's own code).
# HERMES_VOIP_INTERCOM_OPEN_MODE=dtmf
# HERMES_VOIP_INTERCOM_DTMF=9          # the open code; must be valid DTMF (0-9*#A-D)
#
#   relay — POST to an external relay / smart-lock / webhook. The URL MUST be https
#           (it carries a bearer token that must not travel in cleartext). The TOKEN
#           is a SECRET: keep it in 1Password, never commit it.
# HERMES_VOIP_INTERCOM_OPEN_MODE=relay
# HERMES_VOIP_INTERCOM_RELAY_URL=https://lock.example.test/api/open
# HERMES_VOIP_INTERCOM_RELAY_TOKEN=change-me   # 1Password only; never commit
# HERMES_VOIP_INTERCOM_RELAY_METHOD=POST       # POST (default) | GET | PUT
# HERMES_VOIP_INTERCOM_RELAY_TIMEOUT_S=5       # request timeout, seconds (> 0)
#
# The gated `send_dtmf(digits)` agent tool (ELEVATED) is also available on any
# privileged call for IVR navigation / keypad entry — it uses the same RFC 4733
# telephone-event path and requires the gateway to have negotiated telephone-event
# (it raises a clear error otherwise, never silently dropping digits).

# ---------------------------------------------------------------------------
# DTMF RECEIVE (inbound) — ADR-0010 / ADR-0036
# ---------------------------------------------------------------------------
# Inbound DTMF (the caller pressing keys) is decoded by the mechanism HERMES_SIP_DTMF_MODE
# selects (RFC 4733 telephone-event RTP, SIP INFO, or in-band Goertzel) and surfaced two
# ways: (1) while an irreversible tool has ARMED a confirmation
# ("press 1 to confirm"), a digit resolves it directly — the spoof-resistant
# confirmation channel that gates transfer (ADR-0009); (2) otherwise a digit group
# (terminated by `#` or an inter-digit gap) is delivered to the agent as a tagged
# `[DTMF] 1234` turn for IVR-style menu input. Digits NEVER pass through STT/the LLM
# as a fake transcript.
#
# HERMES_SIP_DTMF_MODE selects the DTMF mechanism (send AND receive). All four
# ADR-0010 values are now implemented (ADR-0036) and accepted at config load; an
# unknown value is REJECTED with a loud error.
#   auto     — (default) RFC 4733 telephone-event when the gateway negotiated it.
#   rfc4733  — force RFC 4733 (warns if the gateway negotiated no telephone-event).
#   sip_info — out-of-band DTMF via in-dialog SIP INFO bodies (no telephone-event needed).
#   inband   — in-band Goertzel tone detection / dual-tone generation (G.711 only).
# HERMES_SIP_DTMF_MODE=auto
#
# HERMES_SIP_DTMF_INTERDIGIT_MS — gap (ms) after which a buffered menu group with no
# `#` terminator is delivered. Unset => the built-in default (2000 ms). Must be > 0.
# HERMES_SIP_DTMF_INTERDIGIT_MS=2000
#
# HERMES_SIP_DTMF_INBAND_ENABLED — whether the in-band (Goertzel) last-resort detector
# is permitted under `auto`. DEFAULT true. In `auto` mode on a call where the gateway
# negotiated no telephone-event: if permitted (true) AND the codec is G.711, the in-band
# detector is engaged (it runs); if permitted but non-G.711 the missing-DTMF state is a
# loud "unavailable"; if forbidden (false) the call is a clean "disabled" no-DTMF call.
# (Forcing `inband` above engages the detector directly, independent of this flag.)
# HERMES_SIP_DTMF_INBAND_ENABLED=true
