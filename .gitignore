# Secrets — never commit. The repo is PUBLIC.
.env
.env.*
!.env.example

# Caller-mode list files (ADR-0020): phone numbers are PII and must NEVER be
# committed. These are the default filenames an operator may drop at the repo
# root; the real lists live alongside .env / in 1Password. Any *.caller-*.json
# is ignored so a stray copy cannot be staged by accident.
.caller-allow.json
.caller-deny.json
.caller-grey.json
*.caller-allow.json
*.caller-deny.json
*.caller-grey.json

# Local memory MCP store — never commit
.memory/

# Worktree lanes — disposable, never committed
.worktrees/

# Local model-weight cache — large binaries, NEVER committed (rule 33). The STT/
# TTS/VAD/guard weights are downloaded + sha256-verified at validation time from
# their pinned manifest revisions (see docs/runbooks/0002-voip-live-validation.md);
# the default cache path used there is `.models/`.
.models/

# Python virtualenv, caches, build output
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
.coverage
.coverage.*
htmlcov/

# OS / editor noise
.DS_Store
*.log
